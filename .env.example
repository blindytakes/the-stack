# Database (Phase 1)
DATABASE_URL=
DIRECT_URL=

# Observability (Grafana Cloud OTLP)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Newsletter Provider (Resend or Beehiiv)
NEWSLETTER_PROVIDER=none
NEWSLETTER_SYNC_MAX_RETRIES=2

# Resend
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Beehiiv
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
BEEHIIV_SEND_WELCOME_EMAIL=true

SUPPORT_EMAIL=

# Plan Email Delivery (Resend, reuses RESEND_API_KEY above)
EMAIL_FROM_ADDRESS=plan@thestack.me

# Affiliate Tracking
AFFILIATE_ALLOWED_HOSTS=americanexpress.com,chase.com,capitalone.com,citi.com,discover.com,bankofamerica.com,wellsfargo.com,usbank.com

# Supabase Storage (used by entity asset import scripts)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=entity-images
SUPABASE_STORAGE_PUBLIC_BASE_URL=

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bot Protection (Cloudflare Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Health Check Protection
HEALTH_CHECK_TOKEN=

# Auth (Phase 2)
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
